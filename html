                <button class="tool-btn" data-tool="Pickaxe">Pickaxe</button>
                <button class="tool-btn" data-tool="Axe">Axe</button>
                <button class="tool-btn" data-tool="Shovel">Shovel</button>
                <button class="tool-btn" data-tool="Hoe">Hoe</button>

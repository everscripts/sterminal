<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minecraft Block Asset System</title>
    <style>
        :root {
            --bg-dark: #121212;
            --panel-bg: #1e1e1e;
            --mc-green: #5c8e32;
            --mc-border: #4a4a4a;
            --text-main: #e0e0e0;
            --text-muted: #aaaaaa;
            --accent: #ffaa00;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        header {
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--panel-bg);
            padding: 15px 20px;
            border-radius: 6px;
            border: 2px solid var(--mc-border);
        }

        h1 {
            font-size: 24px;
            color: var(--mc-green);
            text-shadow: 2px 2px 0px #000;
        }

        .controls {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        input, select {
            background: #111;
            border: 2px solid var(--mc-border);
            color: var(--text-main);
            padding: 8px 12px;
            border-radius: 4px;
            outline: none;
        }

        input:focus, select:focus {
            border-color: var(--mc-green);
        }

        .main-layout {
            display: flex;
            gap: 20px;
            flex: 1;
            overflow: hidden;
        }

        .sidebar {
            width: 300px;
            background: var(--panel-bg);
            border: 2px solid var(--mc-border);
            border-radius: 6px;
            padding: 15px;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .tool-selector {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
        }

        .tool-btn {
            background: #2a2a2a;
            border: 2px solid var(--mc-border);
            color: var(--text-main);
            padding: 8px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.2s;
        }

        .tool-btn.active {
            background: var(--mc-green);
            border-color: #7fbf3f;
        }

        .grid-container {
            flex: 1;
            background: var(--panel-bg);
            border: 2px solid var(--mc-border);
            border-radius: 6px;
            padding: 20px;
            overflow-y: auto;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 15px;
            align-content: start;
        }

        .block-card {
            background: #151515;
            border: 2px solid #2d2d2d;
            border-radius: 4px;
            padding: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            user-select: none;
            cursor: pointer;
            transition: transform 0.1s;
        }

        .block-card:hover {
            border-color: #555;
        }

        .block-card:active {
            transform: scale(0.97);
        }

        .image-container {
            position: relative;
            width: 64px;
            height: 64px;
            margin-bottom: 10px;
            image-rendering: pixelated;
            background: #222;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .block-img {
            width: 48px;
            height: 48px;
            object-fit: contain;
        }

        .break-overlay {
            position: absolute;
            top: 8px;
            left: 8px;
            width: 48px;
            height: 48px;
            pointer-events: none;
            opacity: 0.85;
            mix-blend-mode: multiply;
            background-size: cover;
            display: none;
        }

        .block-name {
            font-weight: bold;
            font-size: 14px;
            text-align: center;
            margin-bottom: 6px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            width: 100%;
        }

        .block-meta {
            font-size: 11px;
            color: var(--text-muted);
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .meta-row {
            display: flex;
            justify-content: space-between;
        }

        .meta-val {
            color: var(--accent);
        }

        .progress-bar-container {
            width: 100%;
            height: 4px;
            background: #333;
            margin-top: 8px;
            border-radius: 2px;
            overflow: hidden;
            display: none;
        }

        .progress-bar {
            height: 100%;
            background: #ff3333;
            width: 0%;
            transition: width 0.05s linear;
        }

        .stats-panel {
            background: #111;
            padding: 10px;
            border-radius: 4px;
            border: 1px solid var(--mc-border);
            font-size: 12px;
        }

        .stats-title {
            color: var(--mc-green);
            font-weight: bold;
            margin-bottom: 5px;
        }

        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #151515;
        }
        ::-webkit-scrollbar-thumb {
            background: #444;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #555;
        }
    </style>
</head>
<body>

    <header>
        <h1>Minecraft Block Asset System</h1>
        <div class="controls">
            <input type="text" id="search-input" placeholder="Search blocks...">
            <select id="category-filter">
                <option value="all">All Categories</option>
                <option value="ores">Ores & Minerals</option>
                <option value="nature">Nature & Biomes</option>
                <option value="bricks">Bricks & Design</option>
                <option value="redstone">Redstone & Utility</option>
            </select>
        </div>
    </header>

    <div class="main-layout">
        <div class="sidebar">
            <div class="stats-title">Active Mining Tool</div>
            <div class="tool-selector">
